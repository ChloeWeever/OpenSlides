{
  "name": "openslides",
  "version": "1.1.0",
  "description": "AI-powered presentation editor",
  "main": "src/main/main.js",
  "author": "Chloe Weever",
  "license": "GPL-3.0",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "make": "electron-builder",
    "make:win": "electron-builder --win",
    "make:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.chloeweever.openslides",
    "productName": "OpenSlides",
    "copyright": "Copyright © 2025 Chloe Weever",
    "icon": "src/assets/icon.png",
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenSlides"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "src/assets/icon.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "OpenSlides",
      "icon": "src/assets/icon.png"
    }
  },
  "keywords": [],
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.47",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.6",
    "chart.js": "^4.5.1",
    "electron-store": "^8.2.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  }
}
